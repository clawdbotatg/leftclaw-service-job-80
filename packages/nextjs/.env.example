# =============================================================================
# Animal Kingdom TCG — Frontend env vars
# =============================================================================
# Copy this file to `.env` and fill in values you want active. Every entry is
# OPTIONAL — the app renders without any of them. Missing values surface as
# "not configured" UI states (disabled buttons + helper text), never crashes.
# =============================================================================

# Privy — get from https://dashboard.privy.io.
# Required for email / Google / Apple sign-in and embedded wallets. If unset,
# the "Sign In" button in the header is disabled with a "(unavailable)" hint;
# RainbowKit's "Connect Wallet" still works for crypto-native users.
NEXT_PUBLIC_PRIVY_APP_ID=

# Coinbase Onramp app ID — get from https://portal.cdp.coinbase.com/products/onramp.
# Required for the "Buy with USD" fiat-on-ramp button on /pack. If unset, the
# button is disabled with a tooltip explaining setup is required.
NEXT_PUBLIC_ONRAMP_APP_ID=

# Game server WebSocket URL — set after deploying the /server/ project to
# Railway / Fly.io / your host of choice. Example: wss://akc-server.fly.dev/ws
# If empty, the /battle page renders a "server not configured" empty state and
# does NOT instantiate any WebSocket (defends static export).
NEXT_PUBLIC_GAME_SERVER_WSS=

# Production URL used for OG image absolute paths (Twitter / Discord previews).
# No protocol — just the hostname. Example: animalkingdom.example.com
NEXT_PUBLIC_PRODUCTION_URL=

# Alchemy API key for client-side reads. The app falls back to a public default
# key for local dev; for production you should bring your own.
# Get one at https://dashboard.alchemy.com.
NEXT_PUBLIC_ALCHEMY_API_KEY=

# WalletConnect project ID — used by the WalletConnect connector. The default
# value in scaffold.config.ts works for development; for production traffic,
# create your own at https://cloud.reown.com.
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
