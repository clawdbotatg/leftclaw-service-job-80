# =============================================================================
# Animal Kingdom TCG — Game Server env vars
# =============================================================================
# Copy this file to `.env` (in this /server/ directory) and fill in real values.
# NEVER commit `.env`. The repo's .gitignore + this folder's .gitignore both
# ensure that, but verify before pushing.
# =============================================================================

# WebSocket port the server listens on. Railway / Fly.io will inject their own
# PORT; default 8080 works for local dev.
PORT=8080

# Postgres URL. Required. Match `pg`'s connection string format. Local dev:
# postgresql://postgres:postgres@localhost:5432/animal_kingdom
DATABASE_URL=postgresql://user:pass@host:5432/animal_kingdom

# Alchemy Base mainnet RPC. Public Base RPCs are explicitly forbidden by the
# project's CLAUDE.md. Get a free key at https://dashboard.alchemy.com.
ALCHEMY_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Hot wallet private key. Used for `batchMintPack` calls (and later
# `fuseTrait` for trait progression rewards). MUST hold MINTER_ROLE on
# AnimalKingdomCard, granted by the client multisig at deploy time. Treat as
# a low-balance operational wallet — rotate via the client's Safe ASAP.
HOT_WALLET_PRIVATE_KEY=0xreplacewithadedicatedkeyholdingminterrole

# Privy app credentials. Required to validate `auth` messages from the
# frontend when Privy is configured. If empty, the server falls through to
# address-based auth (insecure — Stage 7 will require SIWE).
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Optional: how long to wait for `auth` after WS connect before closing (ms).
AUTH_TIMEOUT_MS=30000
